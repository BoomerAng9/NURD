# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/nurd_db
PGHOST=localhost
PGPORT=5432
PGUSER=your_user
PGPASSWORD=your_password
PGDATABASE=nurd_db

# Session Security
SESSION_SECRET=your-secure-session-secret-here

# AI Services
OPENAI_API_KEY=sk-your-openai-api-key-here
GROQ_API_KEY=gsk_your-groq-api-key-here
MODAL_API_KEY=your-modal-api-key-here

# Payment Processing
STRIPE_SECRET_KEY=sk_your-stripe-secret-key-here
VITE_STRIPE_PUBLIC_KEY=pk_your-stripe-publishable-key-here

# Optional OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# Development
NODE_ENV=development
# ============================================================================
# NURDSCODE — environment example
# ============================================================================
# Local dev:    cp .env.example .env.local  &  fill in values
# FOAI prod:    .env.local is sourced from openclaw-sop5-openclaw-1 on
#               myclaw-vps via the FOAI secret-pull pattern. Do not commit.
# ============================================================================

# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# ─── Database (Neon serverless Postgres) ────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── Session (REQUIRED — server should fail to boot in prod if missing) ─────
SESSION_SECRET=

# ─── AI Services ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
ASKCODI_API_KEY=
# MODAL_API_KEY=  # Modal Labs — likely dead in code; audit in Phase 1.5

# ─── Payment Processing ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLIC_KEY=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_STANDARD=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_BOOTCAMP=
STRIPE_PRICE_SUBSCRIPTION_MONTHLY=
STRIPE_PRICE_SUBSCRIPTION_YEARLY=

# ─── PayPal ─────────────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_ENVIRONMENT=sandbox

# ─── OAuth Providers ────────────────────────────────────────────────────────
# Note: code reads FACEBOOK_APP_ID/APP_SECRET (not CLIENT_ID/SECRET).
# Trainer auth uses Microsoft (Graph API for Teams meetings).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── Email (nodemailer SMTP) ────────────────────────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="NURD <noreply@nurdscode.com>"

# ─── SendGrid (in deps but usage TBD — Phase 1.5 audit) ─────────────────────
# SENDGRID_API_KEY=
